# ── Database ─────────────────────────────────
# Development: SQLite (default — no changes needed in settings.py)
# Production:  Switch to PostgreSQL by uncommenting the block below
#              and updating settings.py DATABASES to read these env vars.
#
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=plumbers_db
# DB_USER=plumbers_user
# DB_PASSWORD=strongpassword
# DB_HOST=db          # Docker service name (or RDS endpoint on AWS)
# DB_PORT=5432

# SQLite DB lives in the Docker volume at /app/db_volume/db.sqlite3
# (Set this in settings.py: BASE_DIR / 'db_volume' / 'db.sqlite3')
# This ensures the DB persists even when the image is rebuilt.